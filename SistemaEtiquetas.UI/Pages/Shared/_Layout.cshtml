<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Sistema de Etiquetas</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #f8fafc;
            }

            html, body {
                height: 100%;
            }

            .container-fluid {
                display: flex;
                min-height: 100vh;
            }

            .sidebar {
                width: 16.666%;
                background-color: #001623;
                color: white;
                position: fixed;
                left: 0;
                top: 0;
                height: 100vh;
                overflow-y: auto;
                z-index: 1000;
                box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
            }

                .sidebar a {
                    color: #94a3b8;
                    padding: 12px;
                    display: block;
                    border-left: 3px solid transparent;
                    transition: all 0.3s ease;
                }

                    .sidebar a:hover {
                        background-color: #0f172a;
                        color: #FFF200;
                        border-left: 3px solid #FFF200;
                    }

                .sidebar .active {
                    background-color: #0f172a;
                    color: #FFF200;
                    border-left: 3px solid #FFF200;
                }

            .content {
                margin-left: 16.666%;
                width: 83.333%;
                overflow-y: auto;
                padding: 20px;
            }

            .topbar {
                background-color: white;
                border-bottom: 1px solid #e5e7eb;
                padding: 10px 20px;
                position: sticky;
                top: 0;
                z-index: 999;
            }

            .badge-warning {
                background-color: #FFF200;
                color: black;
            }

            .titulo {
                color: #FFF200;
            }

            .btn-primary {
                background-color: #001623;
                border: none;
            }

                .btn-primary:hover {
                    background-color: #0f172a;
                }

            .btn-warning {
                background-color: #FFF200;
                border: none;
                color: black;
            }

                .btn-warning:hover {
                    background-color: #e6d800;
                }

                a {
                    text-decoration: none !important;
                }

            /* Scrollbar customizado */
            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: #0f172a;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: #FFF200;
                border-radius: 3px;
            }

            .sidebar::-webkit-scrollbar-thumb:hover {
                background: #e6d800;
            }
    </style>
</head>
<body>

    <div class="row g-0" style="min-height: 100vh;">

        <!-- MENU LATERAL FIXO -->
        <div class="sidebar col-2">
            <h4 class="p-3 titulo">Resume + DonnaKora</h4>

            <a href="/">📋 Pedidos</a>
            <a href="/Relatorios">📊 Relatórios</a>
            <a href="/Config">⚙️ Configurações</a> 
        </div>

        <!-- CONTEÚDO COM SCROLL -->
        <div class="content col-10">
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>