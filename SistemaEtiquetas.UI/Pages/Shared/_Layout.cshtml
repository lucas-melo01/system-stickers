<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Sistema de Etiquetas</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                overflow-x: hidden;
            }

            .sidebar {
                height: 100vh;
                background-color: #1f2937;
                color: white;
            }

            .sidebar a {
                color: #cbd5e1;
                text-decoration: none;
                display: block;
                padding: 12px;
            }

            .sidebar a:hover {
                background-color: #374151;
                color: white;
            }

            .content {
                padding: 20px;
            }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">

            <!-- MENU LATERAL -->
            <div class="col-2 sidebar">
                <h4 class="p-3">🖨️ Etiquetas</h4>

                <a href="/">📋 Pedidos</a>
                <a href="/Config">⚙️ Configurações</a>
            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 content">
                @RenderBody()
            </div>

        </div>
    </div>

</body>
</html>