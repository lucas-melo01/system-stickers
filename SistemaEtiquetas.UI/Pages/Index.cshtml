@page
@model IndexModel

<div class="d-flex justify-content-between align-items-center mb-4" style="margin-top: 3%">
    <h2 class="mb-0">📦 Pedidos</h2>
    <div class="gap-2" style="display: flex; gap: 10px;">
        <button type="button" class="btn btn-success" onclick="imprimirTodas()" style="background-color: #001623; color: #FFF200; border: none; font-weight: bold;">
            🖨️ Imprimir Etiquetas Pendentes
        </button>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addPedidoModal" style="background-color: #001623; color: #FFF200; border: none; font-weight: bold;">
            ➕ Adicionar Pedido
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Erro!</strong> @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Sucesso!</strong> @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-8">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Buscar por ID, Nome ou CPF..." name="searchTerm" value="@Model.SearchTerm" />
                <button class="btn btn-primary" type="submit">🔍 Buscar</button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <a href="/" class="btn btn-secondary">Limpar</a>
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text">📅 Data</span>
                <input type="date" class="form-control" name="dataPedido" value="@Model.DataPedido?.ToString("yyyy-MM-dd")" />
                <button class="btn btn-primary" type="submit">Filtrar</button>
                @if (Model.DataPedido.HasValue)
                {
                    <a href="/" class="btn btn-secondary">Limpar</a>
                }
            </div>
        </div>
    </div>
</form>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Data Pedido</th>
            <th>Id Pedido</th>
            <th>Nome Cliente - CPF</th>
            <th style="width:450px;">Produto - Cor - Tamanho</th>
            <th>Quantidade</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PedidoItens)
        {
            <tr>
                <td>@item.DataPedido.ToString("dd/MM/yyyy")</td>
                <td>@item.PedidoExternoId</td>
                <td>@item.NomeCliente - @item.ClienteCpf</td>
                <td>@item.Produto - @(item.Cor ?? "N/A") - @(item.Tamanho ?? "N/A")</td>
                <td>@item.Quantidade</td>
                <td>
                    @if (item.Impresso)
                    {
                        <span class="badge bg-success">Impresso</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Pendente</span>
                    }
                </td>
                <td>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#editPedidoModal" onclick="prepareEditModal(@item.PedidoId, @item.PedidoItemId, '@item.Produto', '@(item.Cor ?? "")', '@(item.Tamanho ?? "")', @item.Quantidade)" style="background-color: #001623; border: none; color: #FFF200;">
                        ✏️ Editar
                    </button>
                    <button type="button" class="btn btn-sm btn-info" onclick="previewEtiqueta(@item.PedidoId, @item.PedidoItemId)" style="background-color: #001623; border: none; color: #FFF200;">
                        🖨️ Imprimir
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Controles de Paginação -->
<div class="d-flex justify-content-between align-items-center mt-4">
    <div>
        <span class="text-muted">
            Mostrando <strong>@((Model.PageNumber - 1) * 15 + 1)</strong> 
            até <strong>@Math.Min(Model.PageNumber * 15, Model.TotalItems)</strong> 
            de <strong>@Model.TotalItems</strong> itens
        </span>
    </div>

    <nav aria-label="Paginação">
        <ul class="pagination mb-0">
            <!-- Botão Anterior -->
            @if (Model.PageNumber > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=1&searchTerm=@Model.SearchTerm&dataPedido=@Model.DataPedido?.ToString("yyyy-MM-dd")" aria-label="Primeira Página">
                        ⏮️ Primeira
                    </a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=@(Model.PageNumber - 1)&searchTerm=@Model.SearchTerm&dataPedido=@Model.DataPedido?.ToString("yyyy-MM-dd")" aria-label="Página Anterior">
                        ◀️ Anterior
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">⏮️ Primeira</span>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">◀️ Anterior</span>
                </li>
            }

            <!-- Números de Página -->
            @{
                int startPage = Math.Max(1, Model.PageNumber - 2);
                int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

                if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    if (i == Model.PageNumber)
                    {
                        <li class="page-item active">
                            <span class="page-link">@i</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="?pageNumber=@i&searchTerm=@Model.SearchTerm&dataPedido=@Model.DataPedido?.ToString("yyyy-MM-dd")">@i</a>
                        </li>
                    }
                }

                if (endPage < Model.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            <!-- Botão Próximo -->
            @if (Model.PageNumber < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=@(Model.PageNumber + 1)&searchTerm=@Model.SearchTerm&dataPedido=@Model.DataPedido?.ToString("yyyy-MM-dd")" aria-label="Próxima Página">
                        Próxima ▶️
                    </a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?pageNumber=@Model.TotalPages&searchTerm=@Model.SearchTerm&dataPedido=@Model.DataPedido?.ToString("yyyy-MM-dd")" aria-label="Última Página">
                        Última ⏭️
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Próxima ▶️</span>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Última ⏭️</span>
                </li>
            }
        </ul>
    </nav>
</div>

<!-- Modal para Adicionar Pedido -->
<div class="modal fade" id="addPedidoModal" tabindex="-1" aria-labelledby="addPedidoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addPedidoModalLabel">➕ Adicionar Novo Pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddPedido" id="addPedidoForm">
                <div class="modal-body">
                    <!-- Dados do Pedido -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="idExterno" class="form-label">ID Externo do Pedido *</label>
                            <input type="text" class="form-control" id="idExterno" name="AddPedidoModel.IdExterno" required>
                        </div>
                        <div class="col-md-6">
                            <label for="dataPedido" class="form-label">Data do Pedido *</label>
                            <input type="datetime-local" class="form-control" id="dataPedido" name="AddPedidoModel.DataPedido" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="nomeCliente" class="form-label">Nome do Cliente *</label>
                            <input type="text" class="form-control" id="nomeCliente" name="AddPedidoModel.NomeCliente" required>
                        </div>
                        <div class="col-md-6">
                            <label for="cpfCliente" class="form-label">CPF do Cliente *</label>
                            <input type="text" class="form-control" id="cpfCliente" name="AddPedidoModel.ClienteCpf" placeholder="000.000.000-00" required>
                        </div>
                    </div>

                    <!-- Informações de Venda e Envio -->
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="vendedor" class="form-label">Vendedor</label>
                            <select class="form-control" id="vendedor" name="AddPedidoModel.Vendedor">
                                <option value="">Selecione...</option>
                                <option value="Resume">Resume</option>
                                <option value="DonnaKora">DonnaKora</option>
                                <option value="Manual">Manual</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="tipoEnvio" class="form-label">Tipo de Envio</label>
                            <select class="form-control" id="tipoEnvio" name="AddPedidoModel.TipoEnvio">
                                <option value="">Selecione...</option>
                                <option value="PAC">PAC</option>
                                <option value="SEDEX">SEDEX</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="formaPagamento" class="form-label">Forma de Pagamento</label>
                            <input type="text" class="form-control" id="formaPagamento" name="AddPedidoModel.FormaPagamento" placeholder="Ex: Crédito">
                        </div>
                        <div class="col-md-3">
                            <label for="valorFrete" class="form-label">R$ Frete</label>
                            <input type="number" class="form-control" id="valorFrete" name="AddPedidoModel.ValorFrete" placeholder="0.00" step="0.01" min="0">
                        </div>
                    </div>

                    <!-- Tabela de Itens -->
                    <div class="mb-3">
                        <h6>Itens do Pedido *</h6>
                        <table class="table table-bordered table-sm" id="itensTable">
                            <thead>
                                <tr class="table-secondary">
                                    <th>Produto</th>
                                    <th>SKU</th>
                                    <th>Cor</th>
                                    <th>Tamanho</th>
                                    <th width="80">Qtd</th>
                                    <th width="100">R$ Custo</th>
                                    <th width="100">R$ Venda</th>
                                    <th width="80">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="itensTableBody">
                                <tr class="item-row">
                                    <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].Produto" placeholder="Ex: Camiseta" required></td>
                                    <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].SKU" placeholder="Ex: SKU001"></td>
                                    <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].Cor" placeholder="Ex: Azul"></td>
                                    <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].Tamanho" placeholder="Ex: M"></td>
                                    <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].Quantidade" value="1" min="1" required></td>
                                    <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].ValorCusto" placeholder="0.00" step="0.01" min="0"></td>
                                    <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[0].ValorVenda" placeholder="0.00" step="0.01" min="0"></td>
                                    <td><button type="button" class="btn btn-sm btn-danger btn-remove-item">Remover</button></td>
                                </tr>
                            </tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-primary" id="btnAddItem">➕ Adicionar Item</button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">💾 Salvar Pedido</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para Editar Pedido -->
<div class="modal fade" id="editPedidoModal" tabindex="-1" aria-labelledby="editPedidoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editPedidoModalLabel">✏️ Editar Item do Pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="EditPedidoItem" id="editPedidoForm">
                <div class="modal-body">
                    <input type="hidden" id="pedidoId" name="pedidoId" />
                    <input type="hidden" id="itemId" name="itemId" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="editProduto" class="form-label">Produto *</label>
                            <input type="text" class="form-control" id="editProduto" name="produto" required>
                        </div>
                        <div class="col-md-6">
                            <label for="editCor" class="form-label">Cor</label>
                            <input type="text" class="form-control" id="editCor" name="cor">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="editTamanho" class="form-label">Tamanho</label>
                            <input type="text" class="form-control" id="editTamanho" name="tamanho">
                        </div>
                        <div class="col-md-6">
                            <label for="editQuantidade" class="form-label">Quantidade *</label>
                            <input type="number" class="form-control" id="editQuantidade" name="quantidade" min="1" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success" style="background-color: #001623; border: none; color: #FFF200;">💾 Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para Preview da Etiqueta -->
<div class="modal fade" id="printPreviewModal" tabindex="-1" aria-labelledby="printPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="printPreviewModalLabel">🖨️ Preview da Etiqueta ZPL</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <strong>Informação:</strong> Copie o código ZPL abaixo para testar em um visualizador online ou envie diretamente para a impressora.
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Dados da Etiqueta:</strong></label>
                    <p id="etiquetaInfo"></p>
                </div>
                <div class="mb-3">
                    <label for="zplCode" class="form-label"><strong>Código ZPL:</strong></label>
                    <textarea id="zplCode" class="form-control" rows="12" readonly></textarea>
                </div>
                <button type="button" class="btn btn-primary" onclick="copiarZpl()" style="background-color: #001623; border: none; color: #FFF200;">
                    📋 Copiar ZPL
                </button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-success" onclick="confirmarImpressao()" style="background-color: #001623; border: none; color: #FFF200;">
                    ✅ Confirmar e Marcar como Impresso
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPrintData = null;

    async function previewEtiqueta(pedidoId, itemId) {
        try {
            // Imprimir diretamente sem mostrar o ZPL
            await confirmarImpressaoComId(pedidoId, itemId);
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao imprimir: ' + error.message);
        }
    }

    async function confirmarImpressaoComId(pedidoId, itemId) {
        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const formData = new FormData();
            formData.append('pedidoId', pedidoId);
            formData.append('itemId', itemId);
            formData.append('__RequestVerificationToken', token);

            const response = await fetch('/?handler=confirmprint', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                alert('✅ Etiqueta impressa com sucesso!');
                setTimeout(() => {
                    location.reload();
                }, 500);
            } else {
                alert('❌ Erro ao imprimir: ' + (data.error || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('❌ Erro: ' + error.message);
        }
    }

    async function imprimirTodas() {
        if (!confirm('🖨️ Deseja imprimir TODAS as etiquetas pendentes?')) {
            return;
        }

        const btn = event.target;
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '⏳ Processando...';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const formData = new FormData();
            formData.append('__RequestVerificationToken', token);

            console.log('Enviando requisição para imprimir todas...');

            const response = await fetch('/?handler=imprimirtodas', {
                method: 'POST',
                body: formData
            });

            console.log('Status da resposta:', response.status);
            console.log('Headers:', response.headers);

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const responseText = await response.text();
            console.log('Resposta bruta:', responseText);

            const data = JSON.parse(responseText);

            console.log('Dados recebidos:', data);

            if (data.success) {
                alert(`✅ Sucesso!\n\n${data.impresso} etiqueta(s) impressa(s).\n\n${data.mensagem || ''}`);
                setTimeout(() => {
                    location.reload();
                }, 500);
            } else {
                alert('❌ Erro ao imprimir:\n\n' + (data.error || 'Erro desconhecido'));
                btn.disabled = false;
                btn.textContent = originalText;
            }
        } catch (error) {
            console.error('Erro completo:', error);
            console.error('Stack:', error.stack);
            alert('❌ Erro ao processar:\n\n' + error.message);
            btn.disabled = false;
            btn.textContent = originalText;
        }
    }

    function prepareEditModal(pedidoId, itemId, produto, cor, tamanho, quantidade) {
        document.getElementById('pedidoId').value = pedidoId;
        document.getElementById('itemId').value = itemId;
        document.getElementById('editProduto').value = produto;
        document.getElementById('editCor').value = cor;
        document.getElementById('editTamanho').value = tamanho;
        document.getElementById('editQuantidade').value = quantidade;
    }

    document.addEventListener('DOMContentLoaded', function () {
        let itemCount = 1;

        // Adicionar novo item
        document.getElementById('btnAddItem').addEventListener('click', function () {
            const tbody = document.getElementById('itensTableBody');
            const row = document.createElement('tr');
            row.className = 'item-row';
            row.innerHTML = `
                <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].Produto" placeholder="Ex: Camiseta" required></td>
                <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].SKU" placeholder="Ex: SKU001"></td>
                <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].Cor" placeholder="Ex: Azul"></td>
                <td><input type="text" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].Tamanho" placeholder="Ex: M"></td>
                <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].Quantidade" value="1" min="1" required></td>
                <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].ValorCusto" placeholder="0.00" step="0.01" min="0"></td>
                <td><input type="number" class="form-control form-control-sm" name="AddPedidoModel.Itens[${itemCount}].ValorVenda" placeholder="0.00" step="0.01" min="0"></td>
                <td><button type="button" class="btn btn-sm btn-danger btn-remove-item">Remover</button></td>
            `;
            tbody.appendChild(row);
            itemCount++;

            // Adicionar listener ao novo botão remover
            row.querySelector('.btn-remove-item').addEventListener('click', function () {
                if (document.querySelectorAll('.item-row').length > 1) {
                    row.remove();
                } else {
                    alert('Você deve manter pelo menos um item!');
                }
            });
        });

        // Remover item
        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('btn-remove-item')) {
                e.preventDefault();
                const row = e.target.closest('.item-row');
                if (document.querySelectorAll('.item-row').length > 1) {
                    row.remove();
                } else {
                    alert('Você deve manter pelo menos um item!');
                }
            }
        });

        // Validar formulário antes de enviar
        document.getElementById('addPedidoForm').addEventListener('submit', function (e) {
            const idExterno = document.getElementById('idExterno').value;
            const nomeCliente = document.getElementById('nomeCliente').value;
            const cpf = document.getElementById('cpfCliente').value;
            const dataPedido = document.getElementById('dataPedido').value;
            const itens = document.querySelectorAll('.item-row');

            if (!idExterno || !nomeCliente || !cpf || !dataPedido) {
                e.preventDefault();
                alert('Preencha todos os campos obrigatórios do pedido!');
                return false;
            }

            if (itens.length === 0) {
                e.preventDefault();
                alert('Adicione pelo menos um item ao pedido!');
                return false;
            }

            // Validar CPF (formato básico)
            const cpfRegex = /^\d{3}\.\d{3}\.\d{3}-\d{2}$|^\d{11}$/;
            if (!cpfRegex.test(cpf)) {
                e.preventDefault();
                alert('CPF inválido! Use o formato: 000.000.000-00 ou 00000000000');
                return false;
            }

            // Validar se há pelo menos um produto preenchido
            let temProduto = false;
            itens.forEach(item => {
                const produto = item.querySelector('input[name*=".Produto"]').value;
                if (produto.trim()) {
                    temProduto = true;
                }
            });

            if (!temProduto) {
                e.preventDefault();
                alert('Adicione pelo menos um produto aos itens!');
                return false;
            }
        });
    });
</script>